# ASU Server Configuration
# Copy this to .env and fill in your values

# Redis connection
REDIS_URL=redis://redis:6379

# Public URL -- your Cloudflare Tunnel domain
PUBLIC_PATH=https://asu.yourdomain.com

# Custom ImageBuilder container on ghcr.io
# This is the base container name; ASU appends :{target}-{tag} automatically
BASE_CONTAINER=ghcr.io/YOUR_GITHUB_USERNAME/openwrt-imagebuilder

# Upstream URL for package downloads
# Points to raw GitHub content from pesa1234/MT6000_cust_build
UPSTREAM_URL=https://raw.githubusercontent.com/pesa1234/MT6000_cust_build/refs/heads/main

# Branches configuration (JSON)
# Maps pesa's published branches to container tags and package paths.
# - "name": display name for the version
# - "path": directory in MT6000_cust_build for firmware/metadata
# - "path_packages": package path template ({arch} and {feedname} are replaced by ASU)
# - "targets": maps OpenWrt target to container tag suffix
#
# Update this when pesa publishes new branches.
# Find available branches at: https://github.com/pesa1234/MT6000_cust_build
BRANCHES={"next-r4.8.0.rss.mtk-test6.18": {"name": "r4.8.0-test6.18", "enabled": true, "path": "2026-04-12_r34722-2fff68cf9a_next-r4.8.0.rss.mtk-test6.18", "path_packages": "2026-04-12_r34722-2fff68cf9a_next-r4.8.0.rss.mtk-test6.18/packages/{arch}/{feedname}", "updates": "dev", "targets": {"mediatek/filogic": "next-r4.8.0.rss.mtk-test6.18"}}, "next-r4.7.4.rss.mtk": {"name": "r4.7.4", "enabled": true, "path": "2026-03-20_r34302-4cd1e4be44_next-r4.7.4.rss.mtk", "path_packages": "2026-03-20_r34302-4cd1e4be44_next-r4.7.4.rss.mtk/packages/{arch}/{feedname}", "updates": "dev", "targets": {"mediatek/filogic": "next-r4.7.4.rss.mtk"}}}

# Healthcheck.io UUID for VPS monitoring (used by healthcheck.sh)
HC_UUID=YOUR_HEALTHCHECK_UUID
